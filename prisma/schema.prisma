generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(150)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

model Governorate {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  isActive  Boolean   @default(true) @map("is_active")
  order     Int       @default(0)
  listings  Listing[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("governorates")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(150)
  icon      String?    @db.VarChar(255)
  image     String?    @db.VarChar(255)
  parentId  Int?       @map("parent_id")
  level     Int        @default(1)
  order     Int        @default(0)
  isActive  Boolean    @default(true) @map("is_active")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  listings  Listing[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Listing {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(255)
  description   String?        @db.Text
  categoryId    Int            @map("category_id")
  governorateId Int            @map("governorate_id")
  phone         String?        @db.VarChar(30)
  whatsapp      String?        @db.VarChar(30)
  email         String?        @db.VarChar(150)
  website       String?        @db.VarChar(255)
  instagram     String?        @db.VarChar(150)
  facebook      String?        @db.VarChar(150)
  tiktok        String?        @db.VarChar(150)
  locationLat   Decimal?       @map("location_lat") @db.Decimal(10, 8)
  locationLng   Decimal?       @map("location_lng") @db.Decimal(11, 8)
  address       String?        @db.VarChar(500)
  isFeatured    Boolean        @default(false) @map("is_featured")
  isActive      Boolean        @default(true) @map("is_active")
  viewCount     Int            @default(0) @map("view_count")
  category      Category       @relation(fields: [categoryId], references: [id])
  governorate   Governorate    @relation(fields: [governorateId], references: [id])
  images        ListingImage[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([governorateId])
  @@index([isFeatured])
  @@map("listings")
}

model ListingImage {
  id        Int     @id @default(autoincrement())
  listingId Int     @map("listing_id")
  imageUrl  String  @map("image_url") @db.VarChar(255)
  order     Int     @default(0)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  body      String   @db.Text
  image     String?  @db.VarChar(255)
  linkType  String?  @map("link_type") @db.VarChar(50)
  linkId    Int?     @map("link_id")
  linkUrl   String?  @map("link_url") @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model Ad {
  id        Int       @id @default(autoincrement())
  image     String    @db.VarChar(255)
  linkType  String?   @map("link_type") @db.VarChar(50)
  linkId    Int?      @map("link_id")
  linkUrl   String?   @map("link_url") @db.VarChar(255)
  order     Int       @default(0)
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("ads")
}
